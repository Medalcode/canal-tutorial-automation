+def run_manim(scene_id, manim_code):
+    py_file = os.path.join(OUTPUT_DIR, f"manim_{scene_id}.py")
+    mp4_file = os.path.join(OUTPUT_DIR, f"manim_{scene_id}.mp4")
+    
+    with open(py_file, "w", encoding="utf-8") as f:
+        f.write(manim_code)
+        
+    # Ejecutamos manim en calidad media (720p30fps) y luego lo escalaremos
+    cmd = [
+        "manim", py_file, "SceneAnim",
+        "-q", "h", # Alta calidad 1080p
+        "-o", os.path.abspath(mp4_file),
+        "--format", "mp4",
+        "--media_dir", os.path.abspath(OUTPUT_DIR)
+    ]
+    
+    try:
+        print(f"[{scene_id}] Compilando animacion Manim...")
+        subprocess.run(cmd, check=True, capture_output=True)
+        # Manim guarda el archivo final dependiendo de varios parametros.
+        # Vamos a buscar el .mp4 mas reciente en OUTPUT_DIR si no esta exactamente donde esperamos
+        return mp4_file if os.path.exists(mp4_file) else None
+    except Exception as e:
+        print(f"[{scene_id}] Error compilando Manim: {e}")
+        if hasattr(e, 'stderr') and e.stderr:
+            print(e.stderr.decode(errors="ignore"))
+        return None
